# ═══════════════════════════════════════════════════════════════════════════════
# SECURELENS ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# NODE & ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─────────────────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────
# Local development
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Production (Vercel)
# NEXT_PUBLIC_API_URL=https://your-backend-domain.railway.app/api
# NEXT_PUBLIC_BACKEND_URL=https://your-backend-domain.railway.app

# CORS Origins for backend (comma-separated)
# Local: http://localhost:3000,http://localhost:3001
# Production: https://secure-lens-updated3-frontend-akz4.vercel.app
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────
# Local PostgreSQL
DATABASE_URL=postgresql://securelens:securelens@localhost:5432/securelens

# Railway PostgreSQL (will be auto-provided)
# DATABASE_URL=postgresql://user:password@host:port/database

# ─────────────────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────
# Local Redis
REDIS_URL=redis://localhost:6379

# Railway Redis (will be auto-provided)
# REDIS_URL=redis://user:password@host:port

# ─────────────────────────────────────────────────────────────────────────────────
# JWT & SECURITY
# ─────────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_secure_jwt_secret_change_in_production_min_32_chars
JWT_EXPIRATION=24h

# ─────────────────────────────────────────────────────────────────────────────────
# OAUTH CONFIGURATION (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────────
# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# For Production:
# GITHUB_CALLBACK_URL=https://your-backend-domain.railway.app/api/auth/github/callback

# Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─────────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
ENABLE_PRETTY_LOGS=true

# ─────────────────────────────────────────────────────────────────────────────────
# SECURITY SCANNERS
# ─────────────────────────────────────────────────────────────────────────────────
# These scanners should be installed or accessible in the container
SCANNER_TIMEOUT=300000
NUCLEI_ENABLED=true
TRIVY_ENABLED=true
ZAP_ENABLED=true
SEMGREP_ENABLED=true
GITLEAKS_ENABLED=true
NMAP_ENABLED=true
WHATWEB_ENABLED=true
TESTSSL_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────────
# WORKER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
WORKER_TIMEOUT=600000
WORKER_PROCESS_INTERVAL=5000
